{
	"format_version": "1.19.0",
	"animation_controllers": {
		"test": {
			"initial_state": "idle",
			"states": {
				"idle": {
					"animations": ["state.land.idle"],
					"transitions": [
						{"move": "query.is_sprinting"}
					],
					"blend_transition": 0.15,
					"blend_via_shortest_path": true
				},
				"move": {
					"animations": ["state.land.move"],
					"transitions": [
						{"idle": "!query.is_sprinting"}
					],
					"blend_transition": 0.15,
					"blend_via_shortest_path": true
				}
			}
		}
	}
}