el::textureWidth,\r\n            ByteBufCodecs.INT, OModel::textureHeight,\r\n            OBone.MAP_STREAM_CODEC, OModel::bones,\r\n            ::OModel\r\n        )\r\n\r\n        @JvmStatic\r\n        val ORIGIN_MAP_STREAM_CODEC = ByteBufCodecs.map(\r\n            ::LinkedHashMap,\r\n            ResourceLocation.STREAM_CODEC,\r\n            STREAM_CODEC\r\n        )\r\n    }\r\n\r\n}
