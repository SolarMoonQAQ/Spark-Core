+package cn.solarmoon.spark_core.preinput
+
+import cn.solarmoon.spark_core.event.OnPreInputExecuteEvent
+import net.neoforged.neoforge.common.NeoForge
+
+data class PreInputData(
+    val preInput: PreInput,
+    val id: PreInputId,
+    private val input: () -> Unit,
+    var remain: Int = 0,
+    var maxRemainTime: Int = 5,
+) {
+
+    fun invoke() {
+        val event = NeoForge.EVENT_BUS.post(OnPreInputExecuteEvent.Pre(this))
+        if (event.isCanceled || !preInput.isEnabled) return
+        input.invoke()
+        NeoForge.EVENT_BUS.post(OnPreInputExecuteEvent.Post(this))
+    }
+
+}
